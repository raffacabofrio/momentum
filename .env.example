# Momentum roda em modo demo se este arquivo nao existir como `.env`
# ou se BOARD / BOARD_ALIAS nao estiverem configurados.

# Board Jira da squad
BOARD=1209

# Alias local para resolver a pasta `src/sprint-data-<alias>`
BOARD_ALIAS=danilo

# Credenciais Jira
# Gere um token em: https://id.atlassian.com/manage-profile/security/api-tokens
JIRA_HOST=sua-instancia.atlassian.net
# Opcional: sobrescreve o link base usado ao clicar nos cards
# JIRA_BROWSE_BASE_URL=https://sua-instancia.atlassian.net/browse
JIRA_USER=seu-email@empresa.com
JIRA_API_KEY=seu-token-aqui
